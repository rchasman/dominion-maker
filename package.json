{
  "name": "dominion-maker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --parallel dev:api dev:web",
    "dev:api": "portless api.dominion --app-port 5174 --force bun --watch server.ts",
    "dev:web": "portless dominion --force vite",
    "dev:party": "npx partykit dev",
    "dev:multi": "bun run --parallel dev:api dev:web dev:party",
    "build": "vite build",
    "build:analyze": "ANALYZE=true vite build",
    "type": "tsc --incremental --noEmit",
    "lint": "bun run --parallel lint:fast lint:css",
    "lint:css": "bunx stylelint 'src/**/*.css'",
    "lint:fast": "bunx oxlint",
    "lint:full": "bun run --parallel lint:eslint lint:css",
    "lint:eslint": "bunx eslint .",
    "lint:fix": "bun run --parallel lint:fix:oxlint lint:fix:eslint lint:fix:css",
    "lint:fix:oxlint": "bunx oxlint --fix",
    "lint:fix:eslint": "bunx eslint . --fix",
    "lint:fix:css": "bunx stylelint 'src/**/*.css' --fix",
    "pretty": "bunx prettier . --write --experimental-cli",
    "test": "bun test --concurrent",
    "check:server": "bun server.ts & SERVER_PID=$! && kill $SERVER_PID",
    "check:unused": "depcheck",
    "check:circular": "dpdm --exit-code circular:1 --warning false --tree false 'src/**/*.{ts,tsx}'",
    "check:format": "bunx prettier . --check --experimental-cli",
    "check": "bun run --parallel build type lint test check:server check:unused check:circular check:format",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.97",
    "@ai-sdk/devtools": "^0.0.15",
    "@ai-sdk/openai": "^3.0.85",
    "@floating-ui/dom": "^1.8.0",
    "@preact/signals": "^2.9.4",
    "@toon-format/toon": "^2.3.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.228",
    "partykit": "^0.0.115",
    "partysocket": "^1.3.0",
    "preact": "^10.29.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.5",
    "depcheck": "^1.4.7",
    "dpdm": "^4.2.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.19.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vite-bundle-analyzer": "^1.3.9"
  }
}
