{
  "name": "dominion-maker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun server.ts & vite",
    "dev:party": "npx partykit dev",
    "dev:multi": "npx partykit dev & bun server.ts & vite",
    "build": "vite build",
    "build:analyze": "ANALYZE=true vite build",
    "type": "tsc --incremental --noEmit",
    "lint": "bunx oxlint & bunx stylelint 'src/**/*.css'",
    "lint:fast": "bunx oxlint",
    "lint:full": "bunx eslint . & bunx stylelint 'src/**/*.css'",
    "lint:fix": "bunx oxlint --fix & bunx eslint . --fix & bunx stylelint 'src/**/*.css' --fix",
    "pretty": "bunx prettier . --write --experimental-cli",
    "test": "bun test --concurrent",
    "check:server": "bun server.ts & SERVER_PID=$! && kill $SERVER_PID",
    "check:unused": "depcheck",
    "check:circular": "dpdm --exit-code circular:1 --warning false --tree false 'src/**/*.{ts,tsx}'",
    "check:format": "bunx prettier . --check --experimental-cli",
    "check": "bun run build & bun run type & bun run lint & bun run test & bun check:server & bun check:unused & bun check:circular & bun check:format & wait",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.37",
    "@ai-sdk/devtools": "^0.0.11",
    "@ai-sdk/openai": "3.0.25",
    "@floating-ui/dom": "^1.7.5",
    "@toon-format/toon": "^2.1.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "ai": "6.0.73",
    "partykit": "^0.0.115",
    "partysocket": "^1.1.11",
    "preact": "^10.28.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.2.1",
    "depcheck": "^1.4.7",
    "dpdm": "^4.0.1",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.3.0",
    "oxlint": "^1.43.0",
    "oxlint-tsgolint": "^0.11.4",
    "stylelint": "^17.1.1",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite-bundle-analyzer": "^1.3.6",
    "vite": "^8.0.0-beta.13"
  }
}
